# MultiAgentsArt 环境配置
# 复制为 .env 并填入真实值

# 网络代理配置（按需开启）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# LLM API Keys
GEMINI_API_KEY=your-gemini-api-key-here
# DASHSCOPE_API_KEY=your-dashscope-key-here
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# 面部分析模型（默认 gemini-2.5-flash）
# GEMINI_FACE_MODEL=gemini-2.5-flash

# 多智能体编排器 LLM（支持 gemini/ 前缀，会自动剥离）
DEFAULT_MODEL=gemini/gemini-2.5-flash
# 代码专用模型（可选；不设则与 DEFAULT_MODEL 相同）
# CODE_MODEL=gemini/gemini-2.0-flash

# Builder / Fixer：默认同步 invoke（按 .env 的 CODE_MODEL）；设为 1 才开启流式 + Dashboard 尾部预览
# AGENTSART_CODE_STREAM=0
# AGENTSART_CODE_STREAM_CHARS=900
# AGENTSART_CODE_STREAM_INTERVAL_SEC=0.35
# 流式尾部预览字符数（编排器脱敏后再截断）
# AGENTSART_CODE_STREAM_PREVIEW_CHARS=220
# SSE 单条 preview 硬上限（main.py 再截一层）
# AGENTSART_SSE_PREVIEW_CAP=420

# 编排器短 prompt：1=Builder/Judge/Fixer 用压缩版（省输入 token，需自行 A/B 质量）
# AGENTSART_COMPACT_PROMPTS=1

# 两轮迭代之间最短间隔（秒，默认 300 = 5 分钟）
# AGENTSART_ITERATION_INTERVAL_SEC=300

# 链式演进模式（默认 0 = 每轮独立；设为 1 则继承上一代代码/概念）
# AGENTSART_EVOLUTION_CHAIN=0

# Sensor 页性能降级（展陈长时间运行时）
# AGENTSART_SENSOR_PERF=normal          # low / eco / normal
# AGENTSART_SENSOR_TARGET_FPS=60        # 15-60
# AGENTSART_SENSOR_MAX_DPR=2            # 1.0-3.0
