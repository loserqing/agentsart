# MultiAgentsArt 环境配置
# 复制为 .env 并填入真实值

# 网络代理配置（按需开启）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# LLM API Keys
GEMINI_API_KEY=your-gemini-api-key-here
# DASHSCOPE_API_KEY=your-dashscope-key-here
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# 面部分析模型（默认 gemini-2.5-flash）
# GEMINI_FACE_MODEL=gemini-2.5-flash

# CrewAI 编排器使用的 LLM（litellm 前缀格式）
DEFAULT_MODEL=gemini/gemini-2.5-flash

# 迭代上限（可选）
# ITERATION_LIMIT=5

# 两轮迭代之间最短间隔（秒，默认 300 = 5 分钟）
# AGENTSART_ITERATION_INTERVAL_SEC=300

# 每轮迭代头像采集窗口等待时长（秒，默认 55）
# AGENTSART_FACE_CAPTURE_WAIT_SEC=55

# 链式演进模式（默认 0 = 每轮独立；设为 1 则继承上一代代码/概念）
# AGENTSART_EVOLUTION_CHAIN=0

# Sensor 页性能降级（展陈长时间运行时）
# AGENTSART_SENSOR_PERF=normal          # low / eco / normal
# AGENTSART_SENSOR_TARGET_FPS=60        # 15-60
# AGENTSART_SENSOR_MAX_DPR=2            # 1.0-3.0
